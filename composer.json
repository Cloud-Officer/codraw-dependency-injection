{
    "name": "codraw/dependency-injection",
    "description": "Dependency injection addons to Symfony",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "component",
        "symfony"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "codraw/core": "^0.39",
        "symfony/config": "^6.4.0",
        "symfony/dependency-injection": "^6.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3 || ^12.0"
    },
    "suggest": {
        "phpunit/phpunit": "To use the IntegrationTestCase in your own test suite",
        "symfony/expression-language": "To use the ifExpression tag attribute with TagIfExpressionCompilerPass"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\DependencyInjection\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/dependency-injection": "self.version"
    }
}
